<Window x:Class="MVVMApp.View.WorkerUI.WindowWorker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVMApp.View.WorkerUI"
        xmlns:vmw ="clr-namespace:MVVMApp.ViewModelWorker"
        mc:Ignorable="d"
        Title="WindowWorker" Height="450" Width="800">
    <Window.DataContext>
        <vmw:NavigationVMWorker/>
    </Window.DataContext>
    <Grid>
        <Border CornerRadius="0,20,20,0"
            Background="#1a292b"/>

        <Grid>
            <Grid.ColumnDefinitions >
                <ColumnDefinition  Width="200"/>
                <ColumnDefinition  Width="600"/>
            </Grid.ColumnDefinitions>
        </Grid>

        <Grid HorizontalAlignment="Left"
          Width="200">
            <Border Background="#1a292b"
                CornerRadius="20,0,0,20"/>
            <StackPanel Width="200"
                    Height="430" Background="#1f4347">

                <Button Height="50" Margin="0,10" Command="{Binding AboutWorkerCommand}"
                    Content="Обо мне" FontSize="20"></Button>

                <Button Height="50" Margin="0,10" Command="{Binding SearchVacancyWorkerCommand}" 
                    Content="Поиск вакансий" FontSize="20"></Button>

                <Button Height="50" Margin="0,10" Command="{Binding ResumeWorkerCommand}"
                    Content="Резюме" FontSize="20"></Button>

                <Button Height="50" Margin="0,10"  Command="{Binding SettingsWorkerCommand}"
                    Content="Найстройки" FontSize="20"></Button>

                <Button Height="50" Margin="0,10" Command="{Binding HomeCommandWorker}"
                    Content="На главную" FontSize="20"></Button>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
