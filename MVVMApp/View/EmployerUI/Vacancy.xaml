<UserControl x:Class="MVVMApp.View.EmployerUI.Vacancy"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MVVMApp.View.EmployerUI"
             xmlns:vm ="clr-namespace:MVVMApp.ViewModelEmp"
             xmlns:temp ="clr-namespace:MVVMApp.Other"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600">
    <UserControl.DataContext>
        <vm:VacancyEmpVM/>
    </UserControl.DataContext>
    <Grid Background="#377068">
        <Grid.RowDefinitions>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="391*"/>
            <RowDefinition Height="28*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <TextBlock Text="Поиск резюме"
                       Margin="0,0,222,0"/>
            <TextBox Margin="0,0,222,0"
                     Text="{Binding Row}"/>
            <Button Content="Найти"
                    HorizontalAlignment="Left"
                    Margin="429,0,0,0"/>
            <Button Command="{Binding clearCommand}"
                    Content="Стереть"
                    HorizontalAlignment="Left"
                    Margin="378,0,0,0"/>
        </Grid>
        <Grid Grid.Row="1">
            <ListView Background="#295952" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <Grid Grid.Row="2">
            <Button Command="{Binding addVacancyCommand}"
                    Content="Добавить вакансию"
                    Background="#245761"/>
        </Grid>
    </Grid>
</UserControl>
