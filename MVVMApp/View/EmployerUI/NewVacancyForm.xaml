<Window x:Class="MVVMApp.View.EmployerUI.NewVacancyForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVMApp.View.EmployerUI"
        mc:Ignorable="d"
        xmlns:vm ="clr-namespace:MVVMApp.ViewModelEmp"
        Title="Ваша вакансия" Height="600" Width="800">
    <Window.DataContext>
        <vm:NewVacancyFormVM/>
    </Window.DataContext>
    <Grid Background="#377068">
        <Grid.RowDefinitions>
            <RowDefinition Height="47"/>
            <RowDefinition Height="536*"/>
            <RowDefinition Height="47*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0">
            <TextBlock HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Text="Заполните все поля"
                       FontFamily="Arial Black"
                       FontSize="24"
                       VerticalAlignment="Top"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <TextBox HorizontalAlignment="Left"
                     Margin="35,50,0,0"
                     TextWrapping="Wrap" Text="{Binding TextBoxName,UpdateSourceTrigger=PropertyChanged }"
                     VerticalAlignment="Top" Width="235"/>
            <Label Height="35"
                   Width="165"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"
                   Margin="35,150,0,0"
                   Content="Выберите частоту выплат"/>
            <Label Height="30"
                   Width="130"
                   Margin="35,195,0,0"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"
                   Content="Выберите занятость"/>
            <ComboBox HorizontalAlignment="Left"
                      Margin="35,175,0,0"
                      VerticalAlignment="Top"
                      Width="235"
                      SelectedItem ="{Binding ComboBoxChangePay,UpdateSourceTrigger=PropertyChanged}">
                <TextBlock>Ежедневные</TextBlock>
                <TextBlock>Каждую неделю</TextBlock>
                <TextBlock>Каждый месяц</TextBlock>
                <TextBlock>В год</TextBlock>
            </ComboBox>
            <ComboBox HorizontalAlignment="Left"           
                      Margin="35,0,0,0"
                      VerticalAlignment="Center"            
                      Width="235"
                      SelectedItem="{Binding ComboBoxChangeZanytost ,UpdateSourceTrigger=PropertyChanged}">
                <TextBlock>Полная</TextBlock>
                <TextBlock>Частичная</TextBlock>
                <TextBlock>Гибкий график</TextBlock>
            </ComboBox>
            <TextBox HorizontalAlignment="Left"
                     Margin="35,85,0,0"
                     TextWrapping="Wrap" Text="{Binding TextBoxExp,UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Top" Width="235"/>
            <Label Height="30"
                   Width="135"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"
                   Margin="35,290,0,0"
                   Content="Способ оформления"/>
            <ComboBox HorizontalAlignment="Left"           
                      Margin="34,318,0,0"
                      VerticalAlignment="Top"            
                      Width="235"
                      SelectedItem="{Binding ComboBoxChangeRegistration ,UpdateSourceTrigger=PropertyChanged}">
                <TextBlock>Трудовой договор</TextBlock>
                <TextBlock>Самозанятость</TextBlock>
            </ComboBox>

            <Label Height="25"
                   Width="100"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"
                   Margin="35,380,0,0"
                   Content="Рабочие часы"/>

            <ComboBox HorizontalAlignment="Left"           
                      Margin="34,409,0,0"
                      VerticalAlignment="Top"            
                      Width="235"
                      SelectedItem="{Binding ComboBoxChangeTimeWork ,UpdateSourceTrigger=PropertyChanged}">
                <TextBlock>4</TextBlock>
                <TextBlock>8</TextBlock>
                <TextBlock>12</TextBlock>
                <TextBlock>Индивидуально</TextBlock>
            </ComboBox>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="1">
            <TextBox HorizontalAlignment="Center"
                     Margin="0,44,0,0"
                     TextWrapping="Wrap"
                     Text="{Binding TextBoxAbout,UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Top"
                     Width="380" Height="420"/>
            <TextBlock Text="Напишите что нибудь об этой вакансии"
                       FontSize="18"
                       FontFamily="Bold"
                       Margin="10"/>

        </Grid>
        <Button Background="#298752"
                Content="Создать вакансию"                   
                Grid.Column="0"                   
                Grid.Row="2"
                Command="{Binding addVacancyInList}"/>
        <Button Background="#a1252f"           
                Content="Отмена"                
                Grid.Column="1"                        
                Grid.Row="2"
                Command="{Binding stopCreateVacancyCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Grid>
</Window>
