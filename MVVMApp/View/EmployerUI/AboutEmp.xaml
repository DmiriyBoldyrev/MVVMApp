<UserControl x:Class="MVVMApp.View.EmployerUI.AboutEmp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MVVMApp.View.EmployerUI"
             xmlns:vm ="clr-namespace:MVVMApp.ViewModelEmp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600">
    <UserControl.DataContext>
        <vm:AboutEmpVM/>
    </UserControl.DataContext>
    <Grid Background="#377068">
        <TextBlock Text="Название компании" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top"
                   FontSize="24" Margin="134,34,0,0"/>
        <Image HorizontalAlignment="Left"
               Height="109"
               Margin="10,10,0,0"
               VerticalAlignment="Top"
               Width="120"
               Source="/icons/company.png"/>
        <Button Content="Изменить фото" HorizontalAlignment="Left" Margin="134,4,0,0" VerticalAlignment="Top" Height="30" Width="111"/>
        <TextBlock Text="Название компании" 
            HorizontalAlignment="Left" 
            VerticalAlignment="Top"
            FontSize="24" Margin="10,126,0,0"/>
    </Grid>
</UserControl>
