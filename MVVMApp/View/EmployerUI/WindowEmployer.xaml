<Window x:Class="MVVMApp.View.WindowEmployer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVMApp.View"
        xmlns:vm ="clr-namespace:MVVMApp.ViewModelEmp"
        xmlns:temp ="clr-namespace:MVVMApp.Other"
        mc:Ignorable="d"
        Title="WindowEmployer"
        Background="Transparent"
        Height="450" Width="800" >
    <Window.DataContext>
        <vm:NavigationVM/>
    </Window.DataContext>

    <Grid>

        <Border CornerRadius="0,20,20,0"
                Background="#1a292b"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Grid Grid.Column="0">
                <Border CornerRadius="20,0,0,20" Background="#1f4347"/>
                <StackPanel Margin="0,10">
                    <Button Height="50" Margin="0,10" 
                            Command="{Binding AboutEmpCommand}">
                        <Grid>
                            <Image Source="/icons/company.png" Height="40" Margin="73,0,-64,0" />
                            <TextBlock Text="О компании"
                                       FontSize="20"
                                       HorizontalAlignment="Left" Margin="-45,0,0,0"/>
                        </Grid>
                    </Button>
                    <Button Height="50" Margin="0,10"
                            Command="{Binding SearchResumeCommand}">
                        <Grid>
                            <Image Source="/icons/resume.png" Height="40" Width="70" Margin="79,0,-60,0" />
                            <TextBlock Text="Поиск резюме"
                                       FontSize="20"
                                       HorizontalAlignment="Left" Margin="-45,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button Height="50" Margin="0,10"
                            Command="{Binding VacancyEmpCommand}">
                        <Grid>
                            <Image Source="/icons/vacancy.png" Height="40" Width="70" Margin="79,0,-60,0" />
                            <TextBlock Text="Вакансии" 
                                       FontSize="20"
                                       HorizontalAlignment="Left" Margin="-45,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button Height="50" Margin="0,10" 
                            Command="{Binding SettingsEmpCommand}">
                        <Grid>
                            <Image Source="/icons/settings.png" Height="40" Width="70" Margin="79,0,-60,0" />
                            <TextBlock Text="Найстройки" 
                                       FontSize="20"
                                       HorizontalAlignment="Left" Margin="-45,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button Height="50" Margin="0,10" 
                            Command="{Binding HomeCommand}">
                        <Grid>
                            <Image Source="/icons/main.png" Height="40" Width="70" Margin="79,0,-60,0" />
                            <TextBlock Text="На главную" 
                                       FontSize="20"
                                       HorizontalAlignment="Left" Margin="-45,0,0,0"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>


            <Grid Grid.Column="1" Margin="10">
                <ContentControl Content="{Binding CurrentView}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
