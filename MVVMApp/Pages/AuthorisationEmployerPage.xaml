<Page x:Class="MVVMApp.Pages.AuthorisationEmployerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MVVMApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorisationEmployerPage" Background="#1a292b">

    <Grid>
        <StackPanel VerticalAlignment="Top"
            HorizontalAlignment="Center">
            <TextBlock Text="Введите данные для входа"
               FontSize="34"
               FontWeight="Bold"
               Foreground="#57917f"
               Margin="50"/>
            <TextBox FontWeight="Bold"
             Background="#4b4d30"
             Width="220"
             Height="30"
             FontSize="22"
             Margin="30"
             Text="Введите логин..."
                 x:Name="loginBox"/>
            <PasswordBox FontWeight="Bold"
             Background="#4b4d30"
             Width="220"
             Height="30"
             FontSize="22"
                     x:Name="passwordBox"/>
            <TextBlock Text="Введите пароль..."
               FontWeight="Bold"
               FontSize="22"
               HorizontalAlignment="Center"
               Margin="-30,-30,0,-100"/>
        </StackPanel>
        <Button Content="Войти"
                HorizontalAlignment="Center"
                Margin="0,303,0,0"
                VerticalAlignment="Top"
                Height="33" Width="166"
                Click="AuthClickEmp"/>
    </Grid>
</Page>
