<Page x:Class="MVVMApp.Pages.ChangePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MVVMApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="#1a292b"
      Title="ChangePage">

    <Grid>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
            <TextBlock Text="Вы работник или работадатель?"
               FontSize="36"
               FontWeight="Bold"
               Foreground="#57917f"
               Margin="40,10"/>
            <Button Content="Работник"
                Background="#5c848a"
                Width="280"
                Height="40"
                FontSize="22"
                FontWeight="Bold"
                Margin="40"
                x:Name="WorkerButton" Click="WorkerButton_Click">
            </Button>
            <Button Content="Работодатель"
                Background="#5c848a"
                Width="280"
                Height="40"
                FontSize="22"
                FontWeight="Bold"
                x:Name="EmployerButton" Click="EmployerButton_Click">
            </Button>
        </StackPanel>
    </Grid>
</Page>
