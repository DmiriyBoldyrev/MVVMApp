<Page x:Class="MVVMApp.Pages.EmployerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MVVMApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EmployerPage" Background="#1a292b">

    <Grid>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
            <TextBlock Text="Выберите"
               FontSize="36"
               FontWeight="Bold"
               Foreground="#57917f"
               Margin="40,10"/>
            <Button Content="Войти"
                Background="#5c848a"
                Width="280"
                Height="40"
                FontSize="22"
                FontWeight="Bold"
                Margin="40"
                x:Name="EmployerButtonLog" Click="EmployerButtonLog_Click">
            </Button>
            <Button Content="Зарегестрироваться"
                Background="#5c848a"
                Width="280"
                Height="40"
                FontSize="22"
                FontWeight="Bold"
                x:Name="EmployerButtonReg" Click="EmployerButtonReg_Click">
            </Button>
        </StackPanel>
    </Grid>
</Page>
