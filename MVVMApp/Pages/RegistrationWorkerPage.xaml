<Page x:Class="MVVMApp.Pages.RegistrationWorkerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MVVMApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrationWorkerPage" Background="#1a292b">

    <Grid>
        <StackPanel VerticalAlignment="Top"
                    HorizontalAlignment="Center">
            <TextBlock Text="Введите данные для регистрации"
                     FontSize="34"
                     FontWeight="Bold"
                     Foreground="#57917f"
                     Margin="70"/>
            <TextBox FontWeight="Bold"
                     Background="#4b4d30"
                     Width="240"
                     Height="30"
                     FontSize="22"
                     Margin="10"
                     Text="Придумайте логин..."/>
            <TextBox FontWeight="Bold"
                     Background="#4b4d30"
                     Width="240"
                     Height="30"
                     FontSize="22"
                     Margin="30"
                     Text="Введите Email..."/>
            <PasswordBox FontWeight="Bold"
                     Background="#4b4d30"
                     Width="240"
                     Height="30"
                     FontSize="22"/>
            <TextBlock Text="Придумайте пароль..."
                     FontWeight="Bold"
                     FontSize="22"
                     HorizontalAlignment="Center"
                     Margin="0,-30,0,0"/>
            <PasswordBox FontWeight="Bold"
                     Background="#4b4d30"
                     Width="240"
                     Height="30"
                     FontSize="22"
                     Margin="30"/>
            <TextBlock Text="Повторите пароль..."
                     FontWeight="Bold"
                     FontSize="22"
                     HorizontalAlignment="Center"
                     Margin="-20,-60,0,0"/>
        </StackPanel>
    </Grid>
</Page>
